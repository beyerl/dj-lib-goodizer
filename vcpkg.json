{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "dj-lib-goodizer",
  "version": "0.13.1",
  "description": "Desktop DJ library preparation software (audio standardization & listening-context consistency).",
  "dependencies": [
    "gtest"
  ],
  "features": {
    "audio-backends": {
      "description": "FFmpeg/libebur128/soxr/TagLib audio decode-encode-analysis backends (Milestone 2+).",
      "dependencies": [
        { "name": "ffmpeg", "default-features": false, "features": ["avcodec", "avformat", "swresample"] },
        "libebur128",
        "soxr",
        "taglib",
        "sqlite3"
      ]
    }
  }
}
