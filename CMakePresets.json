{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Ninja, Release, full)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "DJ_BUILD_APP": "ON",
        "DJ_BUILD_CLI": "ON",
        "DJ_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "core",
      "inherits": "default",
      "displayName": "Core only (no Qt) — local dev build",
      "cacheVariables": { "DJ_BUILD_APP": "OFF" }
    },
    {
      "name": "debug",
      "inherits": "default",
      "displayName": "Debug (Ninja)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    }
  ],
  "buildPresets": [
    { "name": "default", "configurePreset": "default" },
    { "name": "core", "configurePreset": "core" },
    { "name": "debug", "configurePreset": "debug" }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "core",
      "configurePreset": "core",
      "output": { "outputOnFailure": true }
    }
  ]
}
